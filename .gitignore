# --- Research data & artefacts (provenance recorded in docs/, never committed) ---
data/
artifacts/

# Local demo rollouts (placeholder policy, NOT experiments — see docs/setup/local-rollout-demo.md)
results/_demo/

# NOTE: results/_smoke/ is intentionally TRACKED (not ignored) — bring-up smoke runs are
# cross-box evidence (e.g. OpenVLA-7B bf16 load on A5000) shared via git. Non-registered
# (no full reproducibility §8 discipline), distinct from write-once registered results/.

# Model weights / checkpoints (record provenance in docs/, never commit binaries)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.gguf
*.onnx

# Third-party paper PDFs (provenance + SHA-256 recorded in docs/references/README.md; re-fetchable)
docs/references/*.pdf

# Submission drafts — progress reports & paper/dissertation working files (author deliverables, kept local)
docs/paper/

# --- Secrets / environment ---
.env
.env.*
*.key
*.pem

# --- Claude Code local (personal) settings ---
.claude/settings.local.json

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
/env/                  # repo-root virtualenv only; configs/env/ stays tracked
*.egg-info/
.ipynb_checkpoints/

# --- OS / editor junk ---
.DS_Store
*.swp
.idea/
.vscode/

# --- graphify knowledge-graph output: derived/regenerable artefact (AST + semantic
